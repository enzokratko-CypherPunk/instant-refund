[package]
name = "kaspa-sidecar"
version = "0.1.0"
edition = "2021"

[dependencies]
anyhow = "1"
axum = "0.7"
tokio = { version = "1", features = ["full"] }
serde = { version = "1", features = ["derive"] }
serde_json = "1"
hex = "0.4"
secp256k1 = { version = "0.29", features = ["rand-std"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }

# Linux-only dependency (signer host)
[target.'cfg(not(windows))'.dependencies]
kaspa-addresses = { version = "0.13.4", default-features = false }
